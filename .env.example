# DataForSEO — required for the SEO score (https://app.dataforseo.com)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Resend — required for the "email me the report" flow (https://resend.com)
RESEND_API_KEY=
# Verified sender. Until you verify your own domain in Resend, leave the default
# below (Resend's onboarding sender) or set this to "Brand <hello@yourdomain.com>".
RESEND_FROM=BizGrader <onboarding@resend.dev>

# Optional branding for the email
STRATEGY_CALL_URL=https://quietcoyotemn.com
BRAND_NAME=Quiet Coyote
